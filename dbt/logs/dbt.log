        hr::numeric                                   as humidity,
        w_med::numeric                                as avg_wind,
        
        extracted_at

    from source
    where
        -- Remove annual summary rows (month 13)
        split_part(fecha, '-', 2)::int between 1 and 12
        -- Only 2019 onwards
        and split_part(fecha, '-', 1)::int >= 2019
)

select * from cleaned
  );
